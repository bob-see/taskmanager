datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model User {
  id           String   @id @default(cuid()) @db.VarChar(36)
  name         String
  email        String   @unique @db.VarChar(191)
  passwordHash String
  role         String   @default("user") @db.VarChar(32)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles               Profile[]
  spaceMemberships       SpaceMember[]
  groupMemberships       UserGroup[]
  matrixCells            MatrixCell[]     @relation("MatrixCellUserValue")
  matrixCellNotes        MatrixCellNote[]
  taskNotes              TaskNote[]
  sentDelegatedTasks     DelegatedTask[]  @relation("DelegatedTaskAssignedBy")
  receivedDelegatedTasks DelegatedTask[]  @relation("DelegatedTaskAssignedTo")
  receivedNotifications  Notification[]   @relation("NotificationRecipient")
  actedNotifications     Notification[]   @relation("NotificationActor")
  notificationPreferences NotificationPreference[]
  notificationPushEnabled Boolean          @default(false)

  @@index([email])
  @@map("user")
}

enum NotificationType {
  SYSTEM
  GENERAL
  DELEGATED_TASK_RECEIVED
  DELEGATED_TASK_ACCEPTED
  DELEGATED_TASK_DECLINED
  DELEGATED_TASK_NOTE_ADDED
  DELEGATED_TASK_COMPLETED
  DELEGATED_TASK_CLOSED
}

model Notification {
  id              String           @id @default(cuid()) @db.VarChar(36)
  recipientUserId String           @db.VarChar(36)
  actorUserId     String?          @db.VarChar(36)
  type            NotificationType @default(GENERAL)
  title           String           @db.VarChar(191)
  body            String?          @db.Text
  targetUrl       String           @db.VarChar(512)
  metadata        Json?
  eventKey        String           @unique @db.VarChar(191)
  readAt          DateTime?
  clearedAt       DateTime?
  createdAt       DateTime         @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, readAt, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([recipientUserId, clearedAt, createdAt])
  @@index([actorUserId])
  @@map("notification")
}

model NotificationPreference {
  id               String           @id @default(cuid()) @db.VarChar(36)
  userId           String           @db.VarChar(36)
  notificationType NotificationType
  inAppEnabled     Boolean          @default(true)
  pushEnabled      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationType])
  @@index([userId])
  @@map("notificationpreference")
}

model Group {
  id          String      @id @default(cuid()) @db.VarChar(36)
  name        String      @unique @db.VarChar(191)
  description String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  memberships UserGroup[]

  @@index([name])
  @@map("usergroup")
}

model UserGroup {
  id        String   @id @default(cuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  groupId   String   @db.VarChar(36)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@map("usergroupmember")
}

model Task {
  id                 String    @id @default(cuid()) @db.VarChar(36)
  title              String
  notes              String?   @db.Text
  dueAt              DateTime?
  completedAt        DateTime?
  completedOn        DateTime?
  orderIndex         Int?
  isPriority         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  startDate          DateTime  @default(now())
  category           String?
  profileId          String?   @default("default") @db.VarChar(36)
  projectId          String?   @db.VarChar(36)
  recurrenceSeriesId String?   @db.VarChar(36)
  repeatEnabled      Boolean   @default(false)
  repeatPattern      String?
  repeatInterval     Int       @default(1)
  repeatDays         Int?
  repeatWeeklyDay    Int?
  repeatMonthlyDay   Int?
  repeatPaused       Boolean   @default(false)
  repeatPauseUntil   DateTime?
  repeatPauseNote    String?   @db.Text

  profile       Profile?       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  noteHistory   TaskNote[]
  delegatedTask DelegatedTask?

  @@unique([profileId, recurrenceSeriesId, startDate])
  @@index([profileId, startDate])
  @@index([profileId, dueAt])
  @@index([profileId, completedOn])
  @@index([profileId, completedOn, orderIndex])
  @@index([profileId, recurrenceSeriesId])
  @@index([projectId])
  @@map("task")
}

enum DelegatedTaskStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CLOSED
  DECLINED
}

model DelegatedTask {
  id               String              @id @default(cuid()) @db.VarChar(36)
  taskId           String              @db.VarChar(36)
  assignedByUserId String?             @db.VarChar(36)
  assignedToUserId String?             @db.VarChar(36)
  status           DelegatedTaskStatus @default(PENDING)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  respondedAt      DateTime?
  acceptedAt       DateTime?
  completedAt      DateTime?
  closedAt         DateTime?

  task           Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("DelegatedTaskAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  assignedToUser User? @relation("DelegatedTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@unique([taskId])
  @@index([assignedByUserId])
  @@index([assignedToUserId])
  @@index([status])
  @@map("delegatedtask")
}

model TaskNote {
  id        String   @id @default(cuid()) @db.VarChar(36)
  taskId    String   @db.VarChar(36)
  userId    String?  @db.VarChar(36)
  content   String   @db.Text
  waitingOn String?
  createdAt DateTime @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([userId])
  @@map("tasknote")
}

model Profile {
  id                    String          @id @default(cuid()) @db.VarChar(36)
  userId                String?         @db.VarChar(36)
  name                  String
  order                 Int
  defaultView           String?
  averageBasis          String?
  routineSupportEnabled Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                 Task[]
  projects              Project[]
  timeEntries           TimeEntry[]
  sundayCheckIns        SundayCheckIn[]

  @@index([userId])
  @@map("profile")
}

model SundayCheckIn {
  id              String   @id @default(cuid()) @db.VarChar(36)
  profileId       String   @db.VarChar(36)
  weekStart       DateTime
  selectedOptions Json
  reflection      String?  @db.Text
  completedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, weekStart])
  @@index([profileId, completedAt])
  @@map("sundaycheckin")
}

model Project {
  id         String    @id @default(cuid()) @db.VarChar(36)
  name       String
  startDate  DateTime  @default(now())
  dueAt      DateTime?
  category   String?
  orderIndex Int?
  archived   Boolean   @default(false)
  collapsed  Boolean   @default(false)
  isPriority Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  profileId  String    @db.VarChar(36)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([profileId, createdAt])
  @@index([profileId, orderIndex])
  @@map("project")
}

model TimeEntry {
  id              String    @id @default(cuid()) @db.VarChar(36)
  profileId       String    @db.VarChar(36)
  entryDate       DateTime
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  loggedMinutes   Int?
  roundingMode    String?
  notes           String?   @db.Text
  source          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, entryDate])
  @@index([entryDate])
  @@index([endTime])
  @@map("timeentry")
}

model ActivityLog {
  id          String   @id @default(cuid()) @db.VarChar(36)
  userId      String   @db.VarChar(36)
  profileId   String?  @db.VarChar(36)
  taskId      String?  @db.VarChar(36)
  projectId   String?  @db.VarChar(36)
  timeEntryId String?  @db.VarChar(36)
  spaceId     String?  @db.VarChar(36)
  type        String   @db.VarChar(64)
  description String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@index([profileId])
  @@index([taskId])
  @@index([projectId])
  @@index([timeEntryId])
  @@index([spaceId])
  @@map("activitylog")
}

model CollaborativeSpace {
  id        String   @id @default(cuid()) @db.VarChar(36)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members SpaceMember[]
  rows    MatrixRow[]
  columns MatrixColumn[]

  @@map("collaborativespace")
}

model SpaceMember {
  id      String @id @default(cuid()) @db.VarChar(36)
  spaceId String @db.VarChar(36)
  userId  String @db.VarChar(36)
  role    String @default("member") @db.VarChar(32)

  space CollaborativeSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([spaceId])
  @@index([userId])
  @@map("spacemember")
}

model MatrixRow {
  id               String    @id @default(cuid()) @db.VarChar(36)
  spaceId          String    @db.VarChar(36)
  name             String
  order            Int
  isDone           Boolean   @default(false)
  doneAt           DateTime?
  cellTypeOverride String?   @db.VarChar(32)

  space CollaborativeSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  cells MatrixCell[]

  @@index([spaceId, order])
  @@map("matrixrow")
}

model MatrixColumn {
  id         String    @id @default(cuid()) @db.VarChar(36)
  spaceId    String    @db.VarChar(36)
  name       String
  type       String    @db.VarChar(32)
  order      Int
  archivedAt DateTime?

  space         CollaborativeSpace   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  statusOptions ColumnStatusOption[]
  cells         MatrixCell[]

  @@index([spaceId, order])
  @@map("matrixcolumn")
}

model ColumnStatusOption {
  id       String @id @default(cuid()) @db.VarChar(36)
  columnId String @db.VarChar(36)
  label    String
  color    String @db.VarChar(32)
  order    Int

  column MatrixColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  cells  MatrixCell[]

  @@index([columnId, order])
  @@map("columnstatusoption")
}

model MatrixCell {
  id             String    @id @default(cuid()) @db.VarChar(36)
  rowId          String    @db.VarChar(36)
  columnId       String    @db.VarChar(36)
  textValue      String?   @db.Text
  numberValue    Decimal?  @db.Decimal(18, 4)
  dateValue      DateTime?
  booleanValue   Boolean?
  statusOptionId String?   @db.VarChar(36)
  userIdValue    String?   @db.VarChar(36)
  notes          String?   @db.Text
  updatedAt      DateTime  @updatedAt

  row          MatrixRow           @relation(fields: [rowId], references: [id], onDelete: Cascade)
  column       MatrixColumn        @relation(fields: [columnId], references: [id], onDelete: Cascade)
  statusOption ColumnStatusOption? @relation(fields: [statusOptionId], references: [id], onDelete: SetNull)
  userValue    User?               @relation("MatrixCellUserValue", fields: [userIdValue], references: [id], onDelete: SetNull)
  noteHistory  MatrixCellNote[]

  @@unique([rowId, columnId])
  @@index([columnId])
  @@index([statusOptionId])
  @@index([userIdValue])
  @@map("matrixcell")
}

model MatrixCellNote {
  id        String   @id @default(cuid()) @db.VarChar(36)
  cellId    String   @db.VarChar(36)
  userId    String   @db.VarChar(36)
  content   String   @db.Text
  createdAt DateTime @default(now())

  cell MatrixCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cellId, createdAt])
  @@index([userId])
  @@map("matrixcellnote")
}
